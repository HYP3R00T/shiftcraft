      "value": "night",
      "operator": ">=",
      "count": 1,
      "scope": {
        "who": {
          "type": "all"
        },
        "when": {
          "type": "day_of_week",
          "values": [
            "monday",
            "tuesday",
            "wednesday",
            "thursday",
            "friday"
          ]
        }
      },
      "enforcement": "hard"
    },
    {
      "id": "rule-006",
      "label": "At most 1 regular shift per day (Mon–Fri)",
      "type": "daily_count",
      "value": "regular",
      "operator": "<=",
      "count": 1,
      "scope": {
        "who": {
          "type": "all"
        },
        "when": {
          "type": "day_of_week",
          "values": [
            "monday",
            "tuesday",
            "wednesday",
            "thursday",
            "friday"
          ]
        }
      },
      "enforcement": "hard"
    },
    {
      "id": "rule-007",
      "label": "At least 1 morning shift per day (weekends)",
      "type": "daily_count",
      "value": "morning",
      "operator": ">=",
      "count": 1,
      "scope": {
        "who": {
          "type": "all"
        },
        "when": {
          "type": "day_type",
          "value": "weekend"
        }
      },
      "enforcement": "hard"
    },
    {
      "id": "rule-008",
      "label": "At least 1 afternoon shift per day (weekends)",
      "type": "daily_count",
      "value": "afternoon",
      "operator": ">=",
      "count": 1,
      "scope": {
        "who": {
          "type": "all"
        },
        "when": {
          "type": "day_type",
          "value": "weekend"
        }
      },
      "enforcement": "hard"
    },
    {
      "id": "rule-009",
      "label": "At least 1 night shift per day (weekends)",
      "type": "daily_count",
      "value": "night",
      "operator": ">=",
      "count": 1,
      "scope": {
        "who": {
          "type": "all"
        },
        "when": {
          "type": "day_type",
          "value": "weekend"
        }
      },
      "enforcement": "hard"
    },
    {
      "id": "rule-010",
      "label": "No regular shift on weekends",
      "type": "daily_count",
      "value": "regular",
      "operator": "==",
      "count": 0,
      "scope": {
        "who": {
          "type": "all"
        },
        "when": {
          "type": "day_type",
          "value": "weekend"
        }
      },
      "enforcement": "hard"
    },
    {
      "id": "rule-011",
      "label": "April 30 requires exactly 1 regular shift (month-end override)",
      "type": "daily_count",
      "value": "regular",
      "operator": "==",
      "count": 1,
      "scope": {
        "who": {
          "type": "all"
        },
        "when": {
          "type": "dates",
          "values": [
            "2026-04-30"
          ]
        }
      },
      "enforcement": "hard"
    },
    {
      "id": "rule-012",
      "label": "Comp-off usage bounded by each employee's earned balance",
      "type": "count_bounded_by_balance",
      "value": "comp_off",
      "balance_source": {
        "type": "numeric",
        "key": "comp_off"
      },
      "scope": {
        "who": {
          "type": "all"
        },
        "when": {
          "type": "always"
        }
      },
      "enforcement": "hard"
    },
    {
      "id": "rule-013",
      "label": "Amogha: prefers day off on Apr 5",
      "type": "value_assignment",
      "value": "annual",
      "scope": {
        "who": {
          "type": "employees",
