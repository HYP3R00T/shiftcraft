{
  "shifts": [
    "morning",
    "afternoon",
    "night",
    "regular"
  ],
  "leave_types": [
    "week_off",
    "annual",
    "comp_off",
    "public_holiday"
  ],
  "solver": {
    "time_limit_seconds": 60,
    "log_progress": false
  },
  "rules": [
    {
      "id": "rule-000",
      "label": "public_holiday blocked — no public holidays declared in this period",
      "type": "value_exclusion",
      "values": [
        "public_holiday"
      ],
      "scope": {
        "who": {
          "type": "all"
        },
        "when": {
          "type": "always"
        }
      },
      "enforcement": "hard"
    },
    {
      "id": "rule-000b",
      "label": "Amogha: annual leave capped at 4 days (number of requested dates)",
      "type": "count_per_period",
      "value": "annual",
      "operator": "<=",
      "count": 4,
      "scope": {
        "who": {
          "type": "employees",
          "ids": [
            "E001"
          ]
        },
        "when": {
          "type": "always"
        }
      },
      "enforcement": "hard"
    },
    {
      "id": "rule-000c",
      "label": "Basheer: annual leave capped at 1 day",
      "type": "count_per_period",
      "value": "annual",
      "operator": "<=",
      "count": 1,
      "scope": {
        "who": {
          "type": "employees",
          "ids": [
            "E003"
          ]
        },
        "when": {
          "type": "always"
        }
      },
      "enforcement": "hard"
    },
    {
      "id": "rule-000d",
      "label": "Pavani: annual leave capped at 2 days",
      "type": "count_per_period",
      "value": "annual",
      "operator": "<=",
      "count": 2,
      "scope": {
        "who": {
          "type": "employees",
          "ids": [
            "E005"
          ]
        },
        "when": {
          "type": "always"
        }
      },
      "enforcement": "hard"
    },
    {
      "id": "rule-000e",
      "label": "Suchi and Anuhya: no annual leave this period (no requests made)",
      "type": "count_per_period",
      "value": "annual",
      "operator": "<=",
      "count": 0,
      "scope": {
        "who": {
          "type": "employees",
          "ids": [
            "E002",
            "E004"
          ]
        },
        "when": {
          "type": "always"
        }
      },
      "enforcement": "hard"
    },
    {
      "id": "rule-001",
      "label": "Exactly 2 week-offs per ISO calendar week",
      "type": "count_per_week",
      "value": "week_off",
      "operator": "==",
      "count": 2,
      "scope": {
        "who": {
          "type": "all"
        },
        "when": {
          "type": "always"
        }
      },
      "enforcement": "hard"
    },
    {
      "id": "rule-001b",
      "label": "At most 2 people on any off state on any given day",
      "type": "daily_count",
      "value": [
        "week_off",
        "annual",
        "comp_off",
        "public_holiday"
      ],
      "operator": "<=",
      "count": 2,
      "scope": {
        "who": {
          "type": "all"
        },
        "when": {
          "type": "always"
        }
      },
      "enforcement": "hard"
    },
    {
      "id": "rule-002",
      "label": "No night shift followed by morning shift the next day",
      "type": "pair_sequence",
      "from_value": "night",
      "to_value": "morning",
      "gap_days": 1,
      "forbidden": true,
      "scope": {
        "who": {
          "type": "all"
        },
        "when": {
          "type": "always"
        }
      },
      "enforcement": "hard"
    },
    {
      "id": "rule-003",
      "label": "At least 1 morning shift per day (Mon–Fri)",
      "type": "daily_count",
      "value": "morning",
      "operator": ">=",
      "count": 1,
      "scope": {
        "who": {
          "type": "all"
        },
        "when": {
          "type": "day_of_week",
          "values": [
            "monday",
            "tuesday",
            "wednesday",
            "thursday",
            "friday"
          ]
        }
      },
      "enforcement": "hard"
    },
    {
      "id": "rule-004",
      "label": "At least 1 afternoon shift per day (Mon–Fri)",
      "type": "daily_count",
      "value": "afternoon",
      "operator": ">=",
      "count": 1,
      "scope": {
        "who": {
          "type": "all"
        },
        "when": {
          "type": "day_of_week",
          "values": [
            "monday",
            "tuesday",
            "wednesday",
            "thursday",
            "friday"
          ]
        }
      },
      "enforcement": "hard"
    },
    {
      "id": "rule-005",
