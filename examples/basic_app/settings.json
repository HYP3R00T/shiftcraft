    {
      "id": "rule-018",
      "label": "Prefer even spread of morning/afternoon/night per employee",
      "type": "spread_per_employee",
      "values": [
        "morning",
        "afternoon",
        "night"
      ],
      "max_diff": 2,
      "scope": {
        "who": {
          "type": "all"
        },
        "when": {
          "type": "always"
        }
      },
      "enforcement": "soft",
      "weight": "medium"
    },
    {
      "id": "rule-019",
      "label": "Prefer equal night shift distribution across the team",
      "type": "spread_across_team",
      "value": "night",
      "max_diff": 2,
      "scope": {
        "who": {
          "type": "all"
        },
        "when": {
          "type": "always"
        }
      },
      "enforcement": "soft",
      "weight": "medium"
    },
    {
      "id": "rule-020",
      "label": "Prefer equal weekend off distribution across the team",
      "type": "spread_across_team",
      "value": "week_off",
      "max_diff": 1,
      "count_when": {
        "type": "day_type",
        "value": "weekend"
      },
      "scope": {
        "who": {
          "type": "all"
        },
        "when": {
